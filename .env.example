# ── Database ─────────────────────────────────────────────
DATABASE_URL="mysql://user:password@host:3306/ecanteen"

# ── Auth.js v5 ──────────────────────────────────────────
NEXTAUTH_SECRET="generate-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ── Midtrans ────────────────────────────────────────────
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"

# ── App URL (used for Midtrans webhook & redirect URLs) ─
# Dev: set to your tunnel URL (e.g. https://xxx.trycloudflare.com)
# Prod: set to your production domain
APP_URL="https://your-domain.com"
